{
    "extends": "astro/tsconfigs/base",
    "compilerOptions": {
        "paths": {
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@assets/*": ["./src/assets/*"],
            "@styles/*": ["./src/styles/*"],
            "@pages/*": ["./src/pages/*"],
            "@scripts/*": ["./src/scripts/*"],
            "@data/*": ["./src/data/*"],
            "@lib/*": ["./src/lib/*"]
        }
    }
}
