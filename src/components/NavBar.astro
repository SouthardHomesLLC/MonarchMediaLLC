---
// src/components/NavBar.astro
interface linkItem {
    linkText: string;
    href: string;
}

const publicItems: linkItem[] = [
    { linkText: 'Home', href: '/' },
    { linkText: 'Portfolio', href: '/portfolio' },
    { linkText: 'Website Development', href: '/web-development' },
    { linkText: 'Care Plans', href: '/care-plans' }
];

const currentPath = Astro.url.pathname;

// Check if contact page is currently active
const isContactActive = currentPath === '/contact' || currentPath.startsWith('/contact/');

const getLinkClass = (href: string) => {
    const isCurrent = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
    return isCurrent
        ? 'text-white bg-white/10 shadow-[inset_0_0_12px_rgba(255,255,255,0.05)] border-t border-white/5 font-semibold'
        : 'text-gray-400 hover:text-white hover:bg-white/5 active:bg-white/10';
};
---

<nav class="flex items-center gap-4 sm:gap-6 relative">
    {/* Desktop Navigation Links */}
    <ul class="hidden md:flex items-center gap-1 sm:gap-2 font-body text-sm font-medium tracking-wide">
        {
            publicItems.map((item) => (
                <li>
                    <a href={item.href} class={`inline-block px-3 py-2 rounded-lg transition-all duration-200 ${getLinkClass(item.href)}`}>
                        {item.linkText}
                    </a>
                </li>
            ))
        }
    </ul>

    {/* The Glassmorphic Contact CTA */}
    <div class="hidden md:block">
        <a
            href="/contact"
            class={`relative inline-flex items-center justify-center font-body
                text-xs font-bold uppercase tracking-[0.15em] px-5 py-2.5
                rounded-xl border transition-all duration-300 group overflow-hidden
                ${
                    isContactActive
                        ? 'border-complementary bg-[#0c0c0e]/90 text-white shadow-[0_4px_25px_rgba(136,69,124,0.35)]'
                        : 'border-white/10 bg-[#0c0c0e]/60 text-white/90 hover:border-complementary/50 hover:shadow-[0_4px_25px_rgba(136,69,124,0.25)] backdrop-blur-md shadow-[0_4px_20px_rgba(0,0,0,0.35)] hover:text-white'
                }`}
        >
            {/* The Top Ambient Accent Line (Stretches fully when active) */}
            <span
                class={`absolute top-0 h-[1.5px] bg-gradient-to-r from-transparent via-complementary to-transparent transition-all duration-300
                    ${
                        isContactActive
                            ? 'left-1 right-1 via-complementary'
                            : 'left-3 right-3 via-complementary/60 group-hover:left-1 group-hover:right-1 group-hover:via-complementary'
                    }`}></span>

            {/* Soft, subtle internal purple glow (Persistently visible when active) */}
            <span
                class={`absolute inset-0 bg-gradient-to-b from-primary/15 to-transparent transition-opacity duration-300
                    ${isContactActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}></span>

            <span class="relative z-10">Get in touch</span>
        </a>
    </div>

    {/* Mobile Toggle */}
    <button
        id="public-menu-toggle"
        type="button"
        class="md:hidden p-2 text-gray-400 hover:text-white focus:outline-none transition-colors"
        aria-label="Toggle Menu"
    >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 menu-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
    </button>

    {/* Mobile Dropdown Menu */}
    <div
        id="public-mobile-menu"
        class="absolute right-0 top-full mt-2 w-48 bg-[#121214]/95 border border-white/5 rounded-xl shadow-2xl p-2 opacity-0 invisible scale-95 transition-all duration-200 z-50 origin-top-right backdrop-blur-md md:hidden"
    >
        <ul class="space-y-1 font-body text-sm font-medium">
            {
                publicItems.map((item) => (
                    <li>
                        <a href={item.href} class={`block px-3 py-2 rounded-lg transition-all ${getLinkClass(item.href)}`}>
                            {item.linkText}
                        </a>
                    </li>
                ))
            }
            {/* Mobile Styled Version of the CTA */}
            <li class="pt-2 mt-2 border-t border-white/5">
                <a
                    href="/contact"
                    class={`relative block text-center font-body text-xs font-bold uppercase tracking-[0.12em] py-2.5 px-3 rounded-lg border transition-all duration-300 overflow-hidden group
                        ${
                            isContactActive
                                ? 'border-complementary bg-[#0c0c0e] text-white shadow-[0_4px_15px_rgba(136,69,124,0.2)]'
                                : 'border-white/10 bg-[#0c0c0e]/80 text-white/90'
                        }`}
                >
                    <span
                        class={`absolute top-0 h-[1.5px] bg-gradient-to-r from-transparent via-complementary to-transparent transition-all duration-300
                            ${isContactActive ? 'left-1 right-1 via-complementary' : 'left-4 right-4 via-complementary/60'}`}></span>
                    Get in touch
                </a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const toggleBtn = document.getElementById('public-menu-toggle');
    const mobileMenu = document.getElementById('public-mobile-menu');

    if (toggleBtn && mobileMenu) {
        toggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !mobileMenu.classList.contains('invisible');

            if (isOpen) {
                mobileMenu.classList.add('opacity-0', 'invisible', 'scale-95');
            } else {
                mobileMenu.classList.remove('opacity-0', 'invisible', 'scale-95');
            }
        });

        document.addEventListener('click', (e) => {
            if (!mobileMenu.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
                mobileMenu.classList.add('opacity-0', 'invisible', 'scale-95');
            }
        });
    }
</script>
