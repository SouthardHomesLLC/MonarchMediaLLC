---
// src/components/admin/EditImageModal.astro
---

<dialog id="edit-modal" class="backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-transparent w-full max-w-md p-4 focus:outline-none">
    <section class="bg-[#121214] border border-white/10 rounded-2xl p-6 shadow-2xl text-white">
        <h3 class="font-header text-xl font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent mb-5">Update Image Metadata</h3>

        <form id="edit-form" class="space-y-5">
            <input type="hidden" id="edit-image-id" name="id" />

            <div class="aspect-video w-full bg-[#1a1a1e] rounded-xl border border-white/5 overflow-hidden flex items-center justify-center">
                <img id="edit-preview-img" src="" alt="Thumbnail preview" class="w-full h-full object-contain" />
            </div>

            <div>
                <label for="edit-alt-input" class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">
                    Alt Text / Description
                </label>

                <input
                    type="text"
                    id="edit-alt-input"
                    name="altText"
                    placeholder="Describe this media for screen readers..."
                    class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-500/60 text-white font-body"
                />
            </div>

            <div class="flex justify-end gap-3 pt-3 border-t border-white/5">
                <button
                    type="button"
                    id="close-edit-modal-btn"
                    class="px-4 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-white/5 hover:bg-white/10 transition-colors border border-white/5 cursor-pointer"
                >
                    Cancel
                </button>

                <button
                    type="submit"
                    id="edit-submit-btn"
                    class="px-5 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-indigo-600 hover:bg-indigo-500 disabled:opacity-60 disabled:cursor-not-allowed text-white transition-colors shadow-md cursor-pointer"
                >
                    Save Changes
                </button>
            </div>
        </form>
    </section>
</dialog>

<script is:inline>
    {
        const editModal = document.getElementById('edit-modal');

        const editForm = document.getElementById('edit-form');

        const editIdInput = document.getElementById('edit-image-id');

        const editAltInput = document.getElementById('edit-alt-input');

        const editPreviewImage = document.getElementById('edit-preview-img');

        const closeEditButton = document.getElementById('close-edit-modal-btn');

        const editSubmitButton = document.getElementById('edit-submit-btn');

        document.addEventListener('click', (event) => {
            const target = event.target;

            if (!(target instanceof Element)) {
                return;
            }

            const editButton = target.closest('.edit-image-btn');

            if (!(editButton instanceof HTMLButtonElement)) {
                return;
            }

            const imageId = editButton.dataset.editId ?? '';

            const imageUrl = editButton.dataset.editUrl ?? '';

            const altText = editButton.dataset.editAlt ?? '';

            if (editIdInput instanceof HTMLInputElement) {
                editIdInput.value = imageId;
            }

            if (editAltInput instanceof HTMLInputElement) {
                editAltInput.value = altText;
            }

            if (editPreviewImage instanceof HTMLImageElement) {
                editPreviewImage.src = imageUrl;
            }

            if (editModal instanceof HTMLDialogElement) {
                editModal.showModal();
            }
        });

        closeEditButton?.addEventListener('click', () => {
            if (editModal instanceof HTMLDialogElement) {
                editModal.close();
            }
        });

        editForm?.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (!(editIdInput instanceof HTMLInputElement) || !(editAltInput instanceof HTMLInputElement)) {
                return;
            }

            const imageId = editIdInput.value;

            if (!imageId) {
                alert('The image ID is missing.');
                return;
            }

            if (editSubmitButton instanceof HTMLButtonElement) {
                editSubmitButton.disabled = true;
                editSubmitButton.textContent = 'Saving...';
            }

            try {
                const response = await fetch(`/api/admin/images/${imageId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        altText: editAltInput.value.trim()
                    })
                });

                if (!response.ok) {
                    const responseText = await response.text();

                    let errorMessage = responseText || 'Failed to update image metadata.';

                    try {
                        const errorData = JSON.parse(responseText);

                        errorMessage = errorData.error ?? errorData.message ?? responseText;
                    } catch {
                        // Preserve plain-text response.
                    }

                    alert(errorMessage);

                    if (editSubmitButton instanceof HTMLButtonElement) {
                        editSubmitButton.disabled = false;

                        editSubmitButton.textContent = 'Save Changes';
                    }

                    return;
                }

                window.location.reload();
            } catch (error) {
                console.error('Image metadata update failed:', error);

                alert('Network error while updating image metadata.');

                if (editSubmitButton instanceof HTMLButtonElement) {
                    editSubmitButton.disabled = false;

                    editSubmitButton.textContent = 'Save Changes';
                }
            }
        });
    }
</script>
