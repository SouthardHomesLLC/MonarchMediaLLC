---
const faqs = [
    {
        question: 'Do unused requests roll over?',
        answer:
            'No. Included requests and support time reset each month so scheduling and capacity remain predictable.'
    },
    {
        question: 'What is not included in a care plan?',
        answer:
            'Major redesigns, new pages, custom application features, third-party integrations, branding projects, and original copywriting are scoped separately.'
    },
    {
        question: 'Can I change plans later?',
        answer:
            'Yes. You can move to a different care plan as your update frequency, support needs, or website complexity changes.'
    },
    {
        question: 'What happens after the initial commitment?',
        answer:
            'After the initial term, monthly plans continue on a recurring basis unless changed or canceled according to the service agreement.'
    },
    {
        question: 'Can Monarch support a custom application?',
        answer:
            'Yes. Bespoke Support is designed for custom backends, databases, APIs, portals, integrations, and business-critical digital systems.'
    }
] as const;
---

<section aria-labelledby="faq-heading">
    <header class="max-w-3xl">
        <p class="font-body text-xs font-bold uppercase tracking-[0.25em] text-header">
            Common questions
        </p>

        <h2 id="faq-heading" class="mt-4 font-header text-4xl text-white sm:text-5xl">
            Monarch Care FAQ
        </h2>
    </header>

    <div class="mt-10 grid gap-4 lg:grid-cols-2">
        {
            faqs.map((faq) => (
                <details class="group rounded-xl border border-white/10 bg-[#0c0c0e]/70 p-6">
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-5 font-subheader text-xl text-white">
                        {faq.question}

                        <span class="text-header transition-transform group-open:rotate-45">
                            +
                        </span>
                    </summary>

                    <p class="mt-4 font-body text-sm leading-7 text-white/55">
                        {faq.answer}
                    </p>
                </details>
            ))
        }
    </div>
</section>
