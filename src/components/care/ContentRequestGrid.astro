---
import { CONTENT_REQUEST_EXAMPLES } from '@data/MonarchCarePlans';

const excludedItems = [
    'New pages or page templates',
    'Original copywriting',
    'Custom application features',
    'Third-party integrations',
    'Major layout redesigns',
    'Branding or logo work'
] as const;
---

<section aria-labelledby="request-heading">
    <header class="max-w-3xl">
        <p class="font-body text-xs font-bold uppercase tracking-[0.25em] text-complementary">
            Content support
        </p>

        <h2
            id="request-heading"
            class="mt-4 font-header text-4xl text-white sm:text-5xl"
        >
            What counts as one request?
        </h2>

        <p class="mt-5 font-body text-base leading-7 text-white/60">
            One request covers a coordinated update to an existing page or
            content area using materials supplied by the client.
        </p>
    </header>

    <div class="mt-10 grid gap-8 xl:grid-cols-[1.7fr_0.8fr]">
        <div class="grid gap-5 sm:grid-cols-2">
            {
                CONTENT_REQUEST_EXAMPLES.map((example) => (
                    <article class="rounded-xl border border-white/10 bg-[#0c0c0e]/70 p-5 transition hover:border-primary/35">
                        <div class="flex items-start justify-between gap-4">
                            <h3 class="font-subheader text-xl text-white">
                                {example.name}
                            </h3>

                            <span class="shrink-0 rounded-full border border-primary/30 bg-primary/20 px-3 py-1 font-body text-[10px] font-semibold uppercase tracking-wider text-purple-200">
                                {example.countsAs} request
                            </span>
                        </div>

                        <p class="mt-3 font-body text-sm leading-6 text-white/55">
                            {example.description}
                        </p>
                    </article>
                ))
            }
        </div>

        <aside class="rounded-2xl border border-white/10 bg-black/20 p-6">
            <p class="font-body text-xs font-bold uppercase tracking-[0.2em] text-white/35">
                Quoted separately
            </p>

            <ul class="mt-5 space-y-4">
                {
                    excludedItems.map((item) => (
                        <li class="flex gap-3 font-body text-sm leading-6 text-white/60">
                            <span class="mt-0.5 text-complementary" aria-hidden="true">
                                ×
                            </span>
                            <span>{item}</span>
                        </li>
                    ))
                }
            </ul>

            <p class="mt-6 border-t border-white/10 pt-5 font-body text-xs leading-6 text-white/35">
                Growth Care improvement time may be applied to smaller layout or
                feature enhancements when they fit within the included monthly
                allowance.
            </p>
        </aside>
    </div>
</section>
