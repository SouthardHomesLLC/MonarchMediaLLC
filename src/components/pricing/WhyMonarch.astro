---
const benefits = [
    {
        title: 'Custom development',
        description:
            'Every project is built around your business instead of forcing your content into a generic page-builder template.'
    },
    {
        title: 'Performance focused',
        description:
            'Responsive layouts, optimized media, and modern delivery practices help keep your website fast and dependable.'
    },
    {
        title: 'SEO foundations',
        description:
            'Technical structure, metadata, semantic markup, and local-search fundamentals are considered from the beginning.'
    },
    {
        title: 'Built to grow',
        description:
            'Your website can evolve from a focused marketing presence into dynamic content, integrations, portals, and custom software.'
    },
    {
        title: 'Direct collaboration',
        description:
            'You work with the people designing and developing your solution rather than being passed between disconnected teams.'
    },
    {
        title: 'Long-term support',
        description:
            'Monarch Care plans provide technical maintenance, content updates, analytics, and ongoing improvements after launch.'
    }
] as const;
---

<section aria-labelledby="why-monarch-heading">
    <header class="mx-auto max-w-3xl text-center">
        <p class="font-body text-xs font-bold uppercase tracking-[0.25em] text-header">
            The Monarch difference
        </p>

        <h2
            id="why-monarch-heading"
            class="mt-4 font-header text-4xl text-white sm:text-5xl"
        >
            More than another website template
        </h2>

        <p class="mt-5 font-body text-base leading-7 text-white/60">
            Monarch combines design, performance, and software engineering to
            create websites that support real business goals.
        </p>
    </header>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
            benefits.map((benefit) => (
                <article class="rounded-2xl border border-white/10 bg-[#0c0c0e]/70 p-6 transition hover:border-primary/35">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full border border-primary/30 bg-primary/15 text-header">
                        <svg
                            aria-hidden="true"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.25"
                            class="h-5 w-5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m4.5 12.75 6 6 9-13.5"
                            />
                        </svg>
                    </div>

                    <h3 class="mt-5 font-subheader text-xl text-white">
                        {benefit.title}
                    </h3>

                    <p class="mt-3 font-body text-sm leading-6 text-white/55">
                        {benefit.description}
                    </p>
                </article>
            ))
        }
    </div>
</section>
