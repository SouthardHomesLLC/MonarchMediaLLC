---
import {
    ADD_ON_CATEGORIES,
    SERVICE_ADD_ONS,
    formatAddOnPrice
} from '@data/ServiceAddons';

const addOnsByCategory = ADD_ON_CATEGORIES.reduce(
    (groups, category) => {
        groups[category] = SERVICE_ADD_ONS.filter(
            (addOn) => addOn.category === category
        );

        return groups;
    },
    {} as Record<
        (typeof ADD_ON_CATEGORIES)[number],
        typeof SERVICE_ADD_ONS
    >
);
---

<section aria-labelledby="add-ons-heading">
    <header class="max-w-3xl">
        <p class="font-body text-xs font-bold uppercase tracking-[0.25em] text-complementary">
            Customize your project
        </p>

        <h2
            id="add-ons-heading"
            class="mt-4 font-header text-4xl text-white sm:text-5xl"
        >
            Optional project add-ons
        </h2>

        <p class="mt-5 font-body text-base leading-7 text-white/60">
            Add specialized content, custom visuals, marketing tools, and
            integrations without moving into a larger package than your project
            requires.
        </p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
            ADD_ON_CATEGORIES.map((category) => (
                <section
                    aria-labelledby={`addon-${category.toLowerCase()}`}
                    class="rounded-2xl border border-white/10 bg-[#0c0c0e]/70 p-6"
                >
                    <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
                        <h3
                            id={`addon-${category.toLowerCase()}`}
                            class="font-subheader text-xl text-white"
                        >
                            {category}
                        </h3>

                        <span class="font-body text-[10px] font-bold uppercase tracking-[0.18em] text-white/30">
                            {addOnsByCategory[category].length} options
                        </span>
                    </div>

                    <div class="mt-3 divide-y divide-white/5">
                        {
                            addOnsByCategory[category].map((addOn) => (
                                <article class="py-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <h4 class="font-body text-sm font-semibold text-white">
                                            {addOn.name}
                                        </h4>

                                        <p class="shrink-0 font-body text-xs font-semibold text-header">
                                            {formatAddOnPrice(addOn)}
                                        </p>
                                    </div>

                                    <p class="mt-2 font-body text-xs leading-5 text-white/45">
                                        {addOn.description}
                                    </p>

                                    <div class="mt-3 flex flex-wrap gap-2">
                                        {
                                            addOn.eligiblePackages.map((packageName) => (
                                                <span class="rounded-full border border-white/10 px-2.5 py-1 font-body text-[10px] text-white/35">
                                                    {packageName}
                                                </span>
                                            ))
                                        }
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </section>
            ))
        }
    </div>
</section>
