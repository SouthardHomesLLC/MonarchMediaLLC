---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import logo from '@assets/MonarchPurple.png';

const socialLinks = [
    {
        label: "Visit Monarch Media LLC's Facebook",
        title: 'Visit Facebook',
        href: 'https://www.facebook.com/61576070392012/',
        icon: 'mdi:facebook'
    },
    {
        label: "Visit Monarch Media LLC's Instagram",
        title: 'Visit Instagram',
        href: 'https://www.instagram.com/monarchmedia.llc',
        icon: 'mdi:instagram'
    },
    {
        label: 'Email Monarch Media LLC',
        title: 'Email Us',
        href: 'mailto:info@monarchmediallc.com',
        icon: 'mdi:email-outline'
    },
    {
        label: 'Call Monarch Media LLC',
        title: 'Call Us',
        href: 'tel:8122432759',
        icon: 'mdi:phone-outline'
    }
] as const;
---

<div class="relative flex min-h-[70svh] select-none flex-col items-center justify-center px-4 pb-4">
    <div
        id="purpleblob"
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-[60vh] w-[60vh]
            -translate-x-1/2 -translate-y-1/2 rounded-full
            bg-primary opacity-40 blur-[40px]"
    >
    </div>

    <Image src={logo} alt="Monarch Media logo" class="z-10 mb-2 w-48 drop-shadow-2xl" />

    <h1
        class="z-10 pb-2 bg-gradient-to-b from-white to-gray-400 bg-clip-text
            text-center font-header text-5xl font-bold tracking-tight
            text-transparent md:text-7xl lg:text-8xl"
    >
        Coming Soon
    </h1>

    <p id="services" class="z-10 pb-8 text-center font-body text-sm font-semibold uppercase
            tracking-[0.2em] text-gray-400 md:text-base">
        Social Media
        <span class="text-primary">|</span>
        Marketing
        <span class="text-primary">|</span>
        Web Design
    </p>

    <p class="z-10 max-w-xl pb-8 text-center font-body text-base leading-relaxed
            text-gray-300 md:text-lg">Metamorphosis in progress.</p>

    <div class="z-10 flex items-center gap-6">
        {
            socialLinks.map((link) => {
                const isExternal = link.href.startsWith('http');

                return (
                    <a
                        href={link.href}
                        aria-label={link.label}
                        title={link.title}
                        target={isExternal ? '_blank' : undefined}
                        rel={isExternal ? 'noreferrer' : undefined}
                        class="flex h-10 w-10 items-center justify-center rounded-full
                            border border-white/10 bg-white/[0.025] text-gray-400
                            transition-all duration-200
                            hover:-translate-y-1 hover:scale-105
                            hover:border-primary/50 hover:bg-primary/15 hover:text-white"
                    >
                        <Icon name={link.icon} class="h-5 w-5" aria-hidden="true" />
                    </a>
                );
            })
        }
    </div>
</div>
