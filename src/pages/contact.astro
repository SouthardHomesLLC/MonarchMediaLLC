---
// src/pages/contact.astro
import Layout from '@layouts/Layout.astro';
import ContactForm from '@components/ContactForm.astro';

// Grab initial parameters if any to pass into our clean component
const { searchParams } = Astro.url;
const selectedService = searchParams.get('service') || '';
---

<Layout title="Get in Touch">
    <main class="relative isolate overflow-hidden min-h-screen">
        {/* Subtle Ambient Background Glows */}
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[45rem] bg-[radial-gradient(circle_at_top,rgba(69,26,107,0.3),transparent_65%)]"
        >
        </div>
        <div
            aria-hidden="true"
            class="pointer-events-none absolute right-[-10%] bottom-[10%] -z-10 h-[30rem] w-[30rem] bg-[radial-gradient(circle,rgba(136,69,124,0.1),transparent_70%)]"
        >
        </div>

        <div class="mx-auto max-w-7xl px-6 py-24 sm:px-8 lg:px-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
                {/* LEFT COLUMN: The "Coming Soon" Announcement */}
                <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-24">
                    {/* Glowing Capsule Badge */}
                    <div class="inline-flex">
                        <span
                            class="inline-flex items-center justify-center px-5 py-2 rounded-full border border-complementary/35 bg-[#0c0c0e]/80 backdrop-blur-md text-complementary text-[10px] font-bold uppercase tracking-[0.25em] shadow-[0_0_15px_rgba(136,69,124,0.15)]"
                        >
                            Services Launching Soon
                        </span>
                    </div>

                    <header class="space-y-4">
                        <h1 class="font-header text-5xl sm:text-6xl text-white leading-none">Secure your spot on the waitlist</h1>
                        <p class="font-body text-base leading-relaxed text-white/60 max-w-md">
                            Monarch Media is preparing to open client onboarding soon. We build premium, high-performance web experiences tailored to scale your
                            brand.
                        </p>
                        <p class="font-body text-sm leading-relaxed text-white/45 max-w-md">
                            Submit an early-access inquiry below. We are reviewing incoming submissions to prioritize our initial design queue.
                        </p>
                    </header>
                </div>

                {/* RIGHT COLUMN: Early Inquiry Form Component */}
                <div class="lg:col-span-7">
                    <div class="rounded-3xl border border-white/10 bg-[#0c0c0e]/70 p-8 sm:p-10 backdrop-blur-md shadow-2xl relative">
                        {/* Interactive Top Accent Line */}
                        <div class="absolute top-0 left-1/12 right-1/12 h-[2px] bg-gradient-to-r from-transparent via-complementary/40 to-transparent"></div>

                        <ContactForm selectedService={selectedService} />
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
