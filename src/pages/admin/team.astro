---
// src/pages/admin/team.astro
import Layout from '@layouts/Layout.astro';
import TeamMemberList from '@components/admin/TeamMemberList.astro';
import TeamMemberForm from '@components/admin/TeamMemberForm.astro';
import type { TeamMemberItem } from '@data/TeamData';
import type { SiteImageItem } from '@data/ImageData';

export const prerender = false;

// Enforce session state check
const token = Astro.cookies.get('admin_token')?.value;
if (!token) {
    return Astro.redirect('/admin/login');
}

const successMessage = Astro.url.searchParams.get('success') || '';
const errorMessage = Astro.url.searchParams.get('error') || '';

const API_BASE_URL = import.meta.env.AZURE_API_URL;

let team: TeamMemberItem[] = [];
let availableImages: SiteImageItem[] = [];

try {
    // 1. Fetch current team members
    const response = await fetch(`${API_BASE_URL}/api/admin/team`, {
        headers: {
            Authorization: `Bearer ${token}`
        }
    });

    if (response.ok) {
        team = await response.json();
    } else {
        console.error(`Backend team fetch returned status code: ${response.status}`);
    }

    // 2. Fetch system images for linking assets
    const imagesResponse = await fetch(`${API_BASE_URL}/api/admin/images`, {
        headers: { Authorization: `Bearer ${token}` }
    });
    if (imagesResponse.ok) {
        availableImages = await imagesResponse.json();
    } else {
        console.error(`Backend images fetch returned status code: ${imagesResponse.status}`);
    }
} catch (e) {
    console.error('Data pull exception handled safely without crashing route:', e);
}

// Check if we are currently trying to edit a specific member
const editTargetId = Astro.url.searchParams.get('edit');
const memberToEdit = editTargetId ? team.find((m) => m.id === parseInt(editTargetId, 10)) : null;
---

<Layout title="Monarch Media | Manage Team">
    <main class="max-w-4xl mx-auto px-4 py-12 text-white space-y-12">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="font-header text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                    Team Manager
                </h1>
                <p class="text-gray-400 font-body text-sm mt-1">Add, update, and manage company team members.</p>
            </div>
            <div>
                <button
                    type="button"
                    id="open-add-modal-btn"
                    class="bg-gradient-to-r from-[#451a6b] to-[#63289a] hover:from-[#52207e] hover:to-[#7430b2] text-white font-body font-semibold text-xs uppercase tracking-wider px-5 py-3 rounded-xl transition-all shadow-md active:scale-[0.99] cursor-pointer"
                >
                    Add Team Member
                </button>
            </div>
        </div>

        {
            successMessage && !memberToEdit && (
                <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 text-emerald-400 font-body text-sm font-medium text-center">
                    {successMessage}
                </div>
            )
        }
        {
            errorMessage && !memberToEdit && (
                <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-red-400 font-body text-sm font-medium text-center">{errorMessage}</div>
            )
        }

        <TeamMemberList team={team} />

        <TeamMemberForm images={availableImages} member={memberToEdit} />
    </main>
</Layout>

<script is:inline>
    {
        const addButton = document.getElementById('open-add-modal-btn');

        const formModal = document.getElementById('team-member-modal');

        const pageSubmitButton = document.getElementById('submit-form-btn');

        addButton?.addEventListener('click', () => {
            if (window.location.search.includes('edit=')) {
                window.history.replaceState({}, '', window.location.pathname);
            }

            const form = document.getElementById('team-member-form');

            const idInput = document.getElementById('member-id');

            const nameInput = document.getElementById('member-name');

            const titleInput = document.getElementById('member-title');

            const imageSelect = document.getElementById('member-image-select');

            const modalTitle = document.getElementById('modal-title-text');

            if (form instanceof HTMLFormElement) {
                form.reset();
            }

            if (idInput instanceof HTMLInputElement) {
                idInput.value = '';
            }

            if (nameInput instanceof HTMLInputElement) {
                nameInput.value = '';
            }

            if (titleInput instanceof HTMLInputElement) {
                titleInput.value = '';
            }

            if (imageSelect instanceof HTMLSelectElement) {
                imageSelect.value = '';
            }

            if (modalTitle) {
                modalTitle.textContent = 'Add New Team Member';
            }

            if (pageSubmitButton instanceof HTMLButtonElement) {
                pageSubmitButton.disabled = false;
                pageSubmitButton.textContent = 'Create Record';
            }

            if (formModal instanceof HTMLDialogElement) {
                formModal.showModal();
            }
        });

        const params = new URLSearchParams(window.location.search);

        if (params.has('edit') && formModal instanceof HTMLDialogElement) {
            formModal.showModal();
        }
    }
</script>
